rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    match /{document=**} {
      allow read, write: if false;
    }
    
    match /nova_channels/{id} {
      allow read, write: if true;
    }
    match /nova_videos_meta/{id} {
      allow read, write: if true;
    }
    match /nova_comments/{id} {
      allow read, write: if true;
    }
    match /nova_posts/{id} {
      allow read, write: if true;
    }
    match /nova_chats/{id} {
      allow read, write: if true;
    }
    match /nova_messages/{id} {
      allow read, write: if true;
    }
    match /nova_playlists/{id} {
      allow read, write: if true;
    }
  }
}
